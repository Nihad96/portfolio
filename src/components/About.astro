---
import { about, stack } from '../data/content';

const categoryColor: Record<string, string> = {
  backend:  'tag-backend',
  frontend: 'tag-frontend',
  tools:    'tag-tools',
  db:       'tag-db',
};
---

<section id="about">
  <div class="container">

    <div class="section-header reveal">
      <span class="section-number accent">01</span>
      <h2 class="section-title">À propos</h2>
    </div>

    <div class="about-grid">
      <div class="about-bio">
        {about.bio.map((paragraph) => (
          <p class="reveal">{paragraph}</p>
        ))}
        <a href={about.cv} download class="cv-link reveal">
          <i class="fa-solid fa-file-arrow-down"></i>
          Télécharger mon CV
        </a>
      </div>

      <div class="about-stack reveal">
        <p class="stack-label">Technologies</p>
        <div class="tag-cloud">
          {stack.map((item) => (
            <span class={`tag ${categoryColor[item.category]}`}>{item.label}</span>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  #about {
    padding-block: 6rem;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .section-number {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.1em;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--text);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-bio p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .cv-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid var(--border-hover);
    padding: 0.6rem 1.1rem;
    border-radius: 6px;
    width: fit-content;
    margin-top: 0.5rem;
    transition: background-color 0.2s, transform 0.15s;
  }

  .cv-link:hover {
    background-color: var(--bg-card);
    transform: translateY(-1px);
  }

  .about-stack {
    position: sticky;
    top: 80px;
  }

  .stack-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    transition: border-color 0.2s, background-color 0.2s;
    cursor: default;
  }

  .tag:hover { border-color: var(--border-hover); background-color: var(--bg-card); }

  /* Category tints */
  .tag-backend  { color: #C6FF00; border-color: rgba(198,255,0,0.2); background-color: rgba(198,255,0,0.05); }
  .tag-frontend { color: #38BDF8; border-color: rgba(56,189,248,0.2); background-color: rgba(56,189,248,0.05); }
  .tag-db       { color: #FB923C; border-color: rgba(251,146,60,0.2); background-color: rgba(251,146,60,0.05); }
  .tag-tools    { color: #A78BFA; border-color: rgba(167,139,250,0.2); background-color: rgba(167,139,250,0.05); }

  :global(.light) .tag-backend  { color: #4D7C0F; border-color: rgba(77,124,15,0.25); background-color: rgba(77,124,15,0.07); }
  :global(.light) .tag-frontend { color: #0369A1; border-color: rgba(3,105,161,0.25); background-color: rgba(3,105,161,0.07); }
  :global(.light) .tag-db       { color: #C2410C; border-color: rgba(194,65,12,0.25); background-color: rgba(194,65,12,0.07); }
  :global(.light) .tag-tools    { color: #6D28D9; border-color: rgba(109,40,217,0.25); background-color: rgba(109,40,217,0.07); }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-stack { position: static; }
  }
</style>
