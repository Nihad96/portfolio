---
import { useTranslations } from "../i18n/utils";
import type { Locale } from "../i18n/ui";
import type { AboutData, Stack } from "../data/types";

interface Props {
  lang: Locale;
  about: AboutData;
  stack: Stack[];
}

const { lang, about, stack } = Astro.props;
const t = useTranslations(lang);

const categoryColor: Record<string, string> = {
  backend: "tag-backend",
  frontend: "tag-frontend",
  tools: "tag-tools",
  db: "tag-db",
};
---

<section id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-number accent">01</span>
      <h2 class="section-title" id="about-heading">{t("about_title")}</h2>
    </div>

    <div class="about-grid">
      <div class="about-bio">
        {about.bio[lang].map((paragraph) => <p class="reveal">{paragraph}</p>)}
        <a
          href={about.cv[lang]}
          target="_blank"
          rel="noopener noreferrer"
          class="cv-link reveal"
        >
          <i class="fa-solid fa-eye" aria-hidden="true"></i>
          {t("about_download_cv")}
        </a>
      </div>

      <div class="about-stack reveal">
        <p class="stack-label">{t("about_tech")}</p>
        <div class="tag-cloud">
          {
            stack.map((item) => (
              <span class={`tag ${categoryColor[item.category]}`}>
                {item.label}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #about {
    padding-block: 6rem;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .section-number {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.1em;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--text);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-bio p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .cv-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid var(--border-hover);
    padding: 0.6rem 1.1rem;
    border-radius: 6px;
    width: fit-content;
    margin-top: 0.5rem;
    transition:
      background-color 0.2s,
      transform 0.15s;
  }

  .cv-link:hover {
    background-color: var(--bg-card);
    transform: translateY(-1px);
  }

  .about-stack {
    position: sticky;
    top: 80px;
  }

  .stack-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    transition:
      border-color 0.2s,
      background-color 0.2s;
    cursor: default;
  }

  .tag:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-card);
  }

  /* Category tints */
  .tag-backend {
    color: var(--color-tag-backend);
    border-color: color-mix(in srgb, var(--color-tag-backend) 20%, transparent);
    background-color: color-mix(in srgb, var(--color-tag-backend) 5%, transparent);
  }
  .tag-frontend {
    color: var(--color-tag-frontend);
    border-color: color-mix(in srgb, var(--color-tag-frontend) 20%, transparent);
    background-color: color-mix(in srgb, var(--color-tag-frontend) 5%, transparent);
  }
  .tag-db {
    color: var(--color-tag-db);
    border-color: color-mix(in srgb, var(--color-tag-db) 20%, transparent);
    background-color: color-mix(in srgb, var(--color-tag-db) 5%, transparent);
  }
  .tag-tools {
    color: var(--color-tag-tools);
    border-color: color-mix(in srgb, var(--color-tag-tools) 20%, transparent);
    background-color: color-mix(in srgb, var(--color-tag-tools) 5%, transparent);
  }

  .tag-backend:hover {
    border-color: color-mix(in srgb, var(--color-tag-backend) 50%, transparent);
    background-color: color-mix(in srgb, var(--color-tag-backend) 12%, transparent);
  }
  .tag-frontend:hover {
    border-color: color-mix(in srgb, var(--color-tag-frontend) 50%, transparent);
    background-color: color-mix(in srgb, var(--color-tag-frontend) 12%, transparent);
  }
  .tag-db:hover {
    border-color: color-mix(in srgb, var(--color-tag-db) 50%, transparent);
    background-color: color-mix(in srgb, var(--color-tag-db) 12%, transparent);
  }
  .tag-tools:hover {
    border-color: color-mix(in srgb, var(--color-tag-tools) 50%, transparent);
    background-color: color-mix(in srgb, var(--color-tag-tools) 12%, transparent);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .about-stack {
      position: static;
    }
  }
</style>
