---
import { jobs, education } from '../data/content';

// Merge and sort all timeline items chronologically (most recent first)
const timeline = [...jobs, ...education].sort((a, b) => {
  const yearA = parseInt(a.period.split(' — ')[1] ?? a.period.split('—')[1] ?? '0');
  const yearB = parseInt(b.period.split(' — ')[1] ?? b.period.split('—')[1] ?? '0');
  return yearB - yearA;
});
---

<section id="experience">
  <div class="container">

    <div class="section-header reveal">
      <span class="section-number accent">02</span>
      <h2 class="section-title">Parcours</h2>
    </div>

    <div class="timeline">
      {timeline.map((item, i) => (
        <article class="timeline-item reveal" style={`transition-delay: ${i * 0.07}s`}>

          <!-- Dot + line -->
          <div class="timeline-marker">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>

          <!-- Content -->
          <div class="timeline-content">
            <div class="timeline-top">
              <div class="timeline-meta">
                <span class="timeline-period">{item.period}</span>
                <span class={`timeline-type ${item.type}`}>
                  {item.type === 'work' ? 'Expérience' : 'Formation'}
                </span>
              </div>
              <div class="timeline-logo">
                <a href={item.url} target="_blank" rel="noopener noreferrer" aria-label={item.company}>
                  <img src={item.logo} alt={item.logoAlt} max-width="70" max-height="70" />
                </a>
              </div>
            </div>

            <div class="timeline-header">
              <h3 class="timeline-role">{item.role}</h3>
              <div class="timeline-company-info">
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="timeline-company">
                  {item.company}
                </a>
                <span class="timeline-location">
                  <i class="fa-solid fa-location-dot"></i>
                  {item.location}
                </span>
              </div>
            </div>

            <p class="timeline-description">{item.description}</p>

            <ul class="timeline-highlights">
              {item.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>

            <div class="timeline-stack">
              {item.stack.map((tech) => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>

<style>
  #experience {
    padding-block: 6rem;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .section-number {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.1em;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--text);
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 0 1.75rem;
  }

  /* Marker */
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 4px;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--accent);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .timeline-item:hover .timeline-dot {
    transform: scale(1.4);
  }

  .timeline-line {
    flex: 1;
    width: 1px;
    background: var(--border);
    margin-top: 6px;
    min-height: 40px;
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  /* Content card */
  .timeline-content {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .timeline-content:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-card-hover);
  }

  .timeline-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .timeline-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .timeline-period {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .timeline-type {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .timeline-type.work {
    background-color: rgba(198, 255, 0, 0.1);
    color: var(--accent);
    border: 1px solid rgba(198, 255, 0, 0.2);
  }

  .timeline-type.education {
    background-color: rgba(56, 189, 248, 0.1);
    color: #38BDF8;
    border: 1px solid rgba(56, 189, 248, 0.2);
  }

  :global(.light) .timeline-type.work {
    background-color: rgba(249, 115, 22, 0.08);
    color: var(--accent);
    border-color: rgba(249, 115, 22, 0.25);
  }

  :global(.light) .timeline-type.education {
    background-color: rgba(217, 119, 6, 0.08);
    color: #D97706;
    border-color: rgba(217, 119, 6, 0.25);
  }

  .timeline-logo {
    max-width: 90px;
    max-height: 60px;
    flex-shrink: 0;
  }

  .timeline-logo img {
    max-width: 90px;
    max-height: 60px;
    object-fit: contain;
    border-radius: 6px;
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  .timeline-logo img:hover { opacity: 1; }

  .timeline-header { margin-bottom: 0.75rem; }

  .timeline-role {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .timeline-company-info {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .timeline-company {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    transition: opacity 0.2s;
  }

  .timeline-company:hover { opacity: 0.75; }

  .timeline-location {
    font-size: 0.8rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .timeline-description {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .timeline-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .timeline-highlights li {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.55;
    padding-left: 1.1rem;
    position: relative;
  }

  .timeline-highlights li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
    top: 0.2rem;
  }

  .timeline-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background-color: var(--border);
    color: var(--text-muted);
    transition: background-color 0.2s, color 0.2s;
  }

  .tech-tag:hover {
    background-color: var(--bg-card-hover);
    color: var(--text);
  }

  @media (max-width: 600px) {
    .timeline-item { grid-template-columns: 20px 1fr; gap: 0 1rem; }
    .timeline-top { flex-direction: column; gap: 0.75rem; }
    .timeline-logo { align-self: flex-start; }
  }
</style>
