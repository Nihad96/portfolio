---
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/ui';
import type { Project } from '../data/types';

interface Props {
  lang: Locale;
  projects: Project[];
}

const { lang, projects } = Astro.props;
const t = useTranslations(lang);
---

<section id="projects">
  <div class="container">

    <div class="section-header reveal">
      <span class="section-number accent">03</span>
      <h2 class="section-title">{t('projects_title')}</h2>
    </div>

    <div class="projects-grid">
      {projects.map((project, i) => (
        <article class="project-card reveal" style={`transition-delay: ${i * 0.1}s`}>
          <div class="card-inner">
            <div class="card-top">
              <div class="card-logo">
                <img src={project.logo} alt={project.logoAlt} width="40" height="40" />
              </div>
              <div class="card-links">
                {project.url && (
                  <a href={project.url} target="_blank" rel="noopener noreferrer" class="card-link" aria-label={`${project.title}`}>
                    <i class="fa-solid fa-arrow-up-right-from-square"></i>
                  </a>
                )}
              </div>
            </div>

            <div class="card-body">
              <span class="card-year">{project.year}</span>
              <h3 class="card-title">{project.title}</h3>
              <p class="card-subtitle">{project.subtitle[lang]}</p>
              <p class="card-description">{project.description[lang]}</p>
            </div>

            <div class="card-stack">
              {project.stack.map((tech) => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  #projects {
    padding-block: 6rem;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .section-number {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.1em;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--text);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .project-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: border-color 0.2s, background-color 0.2s, transform 0.2s;
    overflow: hidden;
  }

  .project-card:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-card-hover);
    transform: translateY(-3px);
  }

  .card-inner {
    padding: 1.75rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .card-logo img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: 6px;
    opacity: 0.9;
  }

  .card-links {
    display: flex;
    gap: 0.5rem;
  }

  .card-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.8rem;
    transition: color 0.2s, border-color 0.2s, background-color 0.2s;
  }

  .card-link:hover {
    color: var(--accent);
    border-color: var(--border-hover);
    background-color: var(--bg);
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .card-year {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    color: var(--text);
    line-height: 1.1;
  }

  .card-subtitle {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .tech-tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background-color: var(--border);
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
