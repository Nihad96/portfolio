---
import { hero, jobs, projects } from '../data/content';

const yearsXp = new Date().getFullYear() - 2021;
const jobCount = jobs.filter((j) => j.type === 'work').length;
const projectCount = projects.length;

const stats = [
  { value: yearsXp, label: "ans d'expérience", suffix: '+' },
  { value: jobCount, label: 'postes en entreprise' },
  { value: projectCount, label: 'projets personnels' },
];
---

<section id="hero">
  <div class="container hero-inner">

    <!-- Text side -->
    <div class="hero-text">
      <p class="hero-eyebrow reveal">Strasbourg, France</p>

      <h1 class="hero-name reveal">
        {hero.name.split(' ').map((word) => (
          <span class="name-word">{word}<br /></span>
        ))}
      </h1>

      <p class="hero-title reveal">
        <span class="accent">—</span> {hero.title}
      </p>

      <p class="hero-subtitle reveal">{hero.subtitle}</p>

      <div class="hero-ctas reveal">
        <a href={hero.cta.primary.href} class="cta-primary">{hero.cta.primary.label}</a>
        <a href={hero.cta.secondary.href} class="cta-secondary">{hero.cta.secondary.label}</a>
      </div>

      <!-- Stats -->
      <div class="hero-stats reveal">
        {stats.map((stat) => (
          <div class="stat">
            <div class="stat-number">
              <span class="stat-value" data-target={stat.value}>0</span>
              {stat.suffix && <span class="stat-suffix accent">{stat.suffix}</span>}
            </div>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Photo side -->
    <div class="hero-photo reveal">
      <div class="photo-frame">
        <img src={hero.photo} alt={hero.photoAlt} loading="eager" />
      </div>
      <div class="photo-accent-line"></div>
    </div>

  </div>
</section>

<script is:inline>
  // Animate stat counters when they become visible
  function animateCounters() {
    document.querySelectorAll('.stat-value[data-target]').forEach(function (el) {
      const target = parseInt(el.getAttribute('data-target'), 10);
      const duration = 1200;
      const step = Math.ceil(duration / target);
      let current = 0;
      const timer = setInterval(function () {
        current += 1;
        el.textContent = current;
        if (current >= target) {
          clearInterval(timer);
          el.textContent = target;
        }
      }, step);
    });
  }

  const statsBlock = document.querySelector('.hero-stats');
  if (statsBlock) {
    const obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          animateCounters();
          obs.disconnect();
        }
      });
    }, { threshold: 0.5 });
    obs.observe(statsBlock);
  }
</script>

<style>
  #hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    padding-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  /* Subtle grid background */
  #hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 100%);
    pointer-events: none;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    flex: 1;
    max-width: 580px;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .hero-name {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 9vw, 8rem);
    line-height: 0.92;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 440px;
    margin-bottom: 2rem;
    line-height: 1.65;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    background-color: var(--accent);
    color: #0C0C0C;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.7rem 1.4rem;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: background-color 0.2s, transform 0.15s;
    letter-spacing: 0.02em;
  }

  :global(.light) .cta-primary {
    color: #ffffff;
  }

  .cta-primary:hover {
    background-color: var(--accent-hover);
    transform: translateY(-2px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
    color: var(--text);
    font-weight: 500;
    font-size: 0.9rem;
    padding: 0.7rem 1.4rem;
    border-radius: 8px;
    transition: border-color 0.2s, background-color 0.2s, transform 0.15s;
  }

  .cta-secondary:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-card);
    transform: translateY(-2px);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-number {
    display: flex;
    align-items: flex-end;
    line-height: 1;
    gap: 0.05em;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    line-height: 1;
    color: var(--text);
  }

  .stat-suffix {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    line-height: 1;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Photo */
  .hero-photo {
    flex-shrink: 0;
    position: relative;
    width: clamp(260px, 28vw, 380px);
  }

  .photo-frame {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }

  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(20%);
    transition: filter 0.3s;
  }

  .photo-frame:hover img {
    filter: grayscale(0%);
  }

  .photo-accent-line {
    position: absolute;
    bottom: -12px;
    right: -12px;
    width: 60%;
    height: 60%;
    border-bottom: 2px solid var(--accent);
    border-right: 2px solid var(--accent);
    border-radius: 0 0 12px 0;
    z-index: 0;
  }

  /* Staggered reveal delays */
  .hero-text .reveal:nth-child(1) { transition-delay: 0.05s; }
  .hero-text .reveal:nth-child(2) { transition-delay: 0.1s; }
  .hero-text .reveal:nth-child(3) { transition-delay: 0.15s; }
  .hero-text .reveal:nth-child(4) { transition-delay: 0.2s; }
  .hero-text .reveal:nth-child(5) { transition-delay: 0.25s; }
  .hero-text .reveal:nth-child(6) { transition-delay: 0.3s; }
  .hero-photo.reveal             { transition-delay: 0.2s; }

  @media (max-width: 900px) {
    .hero-inner {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 2.5rem;
    }
    .hero-photo {
      width: clamp(160px, 50vw, 260px);
      align-self: flex-end;
    }
  }

  @media (max-width: 480px) {
    .hero-name { font-size: clamp(3.5rem, 16vw, 5rem); }
    .hero-stats { gap: 1.5rem; }
  }
</style>
