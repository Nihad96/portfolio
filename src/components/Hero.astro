---
import { useTranslations } from "../i18n/utils";
import type { Locale } from "../i18n/ui";
import type { HeroData, Job, Project } from "../data/types";

interface Props {
  lang: Locale;
  hero: HeroData;
  jobs: Job[];
  projects: Project[];
}

const { lang, hero, jobs, projects } = Astro.props;
const t = useTranslations(lang);

const yearsXp = new Date().getFullYear() - 2021;
const jobCount = jobs.filter((j) => j.type === "work").length;
const projectCount = projects.length;

const stats = [
  { value: yearsXp, label: t("stat_xp"), suffix: "+" },
  { value: jobCount, label: t("stat_jobs") },
  { value: projectCount, label: t("stat_projects") },
];

const heroPhotoFallback = hero.photo.replace(/\.webp$/i, ".png");
---

<section id="hero" aria-labelledby="hero-name">
  <div class="container hero-inner">
    <!-- Text side -->
    <div class="hero-text">
      <!-- Mobile: top row (eyebrow + name) side by side with photo -->
      <div class="hero-top-row">
        <div class="hero-top">
          <p class="hero-eyebrow reveal">{t("hero_eyebrow")}</p>

          <h1 class="hero-name reveal" id="hero-name">
            {
              hero.name.split(" ").map((word) => (
                <span class="name-word">
                  {word}
                  <br />
                </span>
              ))
            }
          </h1>
        </div>

        <!-- Photo side (moved inside hero-text for mobile row, hidden on desktop) -->
        <div class="hero-photo-mobile reveal">
          <div class="photo-frame">
            <picture>
              <source srcset={hero.photo} type="image/webp" />
              <img
                src={heroPhotoFallback}
                alt={hero.photoAlt}
                loading="eager"
                fetchpriority="high"
                width="380"
                height="380"
              />
            </picture>
          </div>
          <div class="photo-accent-line"></div>
        </div>
      </div>

      <p class="hero-title reveal">
        <span class="accent">—</span>
        {hero.title[lang]}
      </p>

      <p class="hero-subtitle reveal">{hero.subtitle[lang]}</p>

      <div class="hero-ctas reveal">
        <a href={hero.cta.primary.href} class="cta-primary"
          >{hero.cta.primary.label[lang]}</a
        >
        <a href={hero.cta.secondary.href} class="cta-secondary"
          >{hero.cta.secondary.label[lang]}</a
        >
      </div>

      <!-- Stats -->
      <div class="hero-stats reveal">
        {
          stats.map((stat) => (
            <div class="stat">
              <div class="stat-number">
                <span class="stat-value" data-target={stat.value}>
                  0
                </span>
                {stat.suffix && (
                  <span class="stat-suffix accent">{stat.suffix}</span>
                )}
              </div>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Photo side (desktop only) -->
    <div class="hero-photo reveal">
      <div class="photo-frame">
        <picture>
          <source srcset={hero.photo} type="image/webp" />
          <img
            src={heroPhotoFallback}
            alt={hero.photoAlt}
            loading="eager"
            fetchpriority="high"
            width="380"
            height="380"
          />
        </picture>
      </div>
      <div class="photo-accent-line"></div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const statsBlock = document.querySelector(".hero-stats");
    if (!statsBlock) return;

    function cssTimeToMs(value) {
      value = value.trim();
      if (value.endsWith("ms")) return parseFloat(value);
      return parseFloat(value) * 1000;
    }

    function animateCounters() {
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      document
        .querySelectorAll(".stat-value[data-target]")
        .forEach(function (el) {
          const target = parseInt(el.getAttribute("data-target"), 10);

          if (prefersReduced || target <= 0) {
            el.textContent = target;
            return;
          }

          const duration = 1200;
          let start = null;

          function step(timestamp) {
            if (!start) start = timestamp;
            const elapsed = timestamp - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(eased * target);
            if (progress < 1) {
              requestAnimationFrame(step);
            } else {
              el.textContent = target;
            }
          }

          requestAnimationFrame(step);
        });
    }

    function startWithRevealOverlap() {
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (prefersReduced) {
        animateCounters();
        return;
      }

      const style = getComputedStyle(statsBlock);
      const delayMs = cssTimeToMs(style.transitionDelay.split(",")[0]);
      const durationMs = cssTimeToMs(style.transitionDuration.split(",")[0]);
      // Midpoint between instant start and waiting for full reveal (~375ms)
      setTimeout(animateCounters, (delayMs + durationMs) / 2);
    }

    function whenVisible() {
      if (statsBlock.classList.contains("visible")) {
        startWithRevealOverlap();
        return;
      }

      const mo = new MutationObserver(function () {
        if (statsBlock.classList.contains("visible")) {
          mo.disconnect();
          startWithRevealOverlap();
        }
      });
      mo.observe(statsBlock, { attributes: true, attributeFilter: ["class"] });
    }

    whenVisible();
  })();
</script>

<style>
  #hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    padding-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  /* Subtle grid background */
  #hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(
      ellipse 80% 70% at 50% 50%,
      black 30%,
      transparent 100%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 80% 70% at 50% 50%,
      black 30%,
      transparent 100%
    );
    pointer-events: none;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    flex: 1;
    max-width: 580px;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .hero-name {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 9vw, 8rem);
    line-height: 0.92;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 440px;
    margin-bottom: 2rem;
    line-height: 1.65;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    background-color: var(--accent);
    color: var(--color-on-accent);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.7rem 1.4rem;
    border-radius: 8px;
    border: 1px solid transparent;
    transition:
      background-color 0.2s,
      transform 0.15s;
    letter-spacing: 0.02em;
  }

  .cta-primary:hover {
    background-color: var(--accent-hover);
    transform: translateY(-2px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
    color: var(--text);
    font-weight: 500;
    font-size: 0.9rem;
    padding: 0.7rem 1.4rem;
    border-radius: 8px;
    transition:
      border-color 0.2s,
      background-color 0.2s,
      transform 0.15s;
  }

  .cta-secondary:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-card);
    transform: translateY(-2px);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-number {
    display: flex;
    align-items: flex-end;
    line-height: 1;
    gap: 0.05em;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    line-height: 1;
    color: var(--text);
  }

  .stat-suffix {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    line-height: 1;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Photo */
  .hero-photo {
    flex-shrink: 0;
    position: relative;
    width: clamp(260px, 28vw, 380px);
  }

  .photo-frame {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }

  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(20%);
    transition: filter 0.3s;
  }

  .photo-frame:hover img {
    filter: grayscale(0%);
  }

  .photo-accent-line {
    position: absolute;
    bottom: -12px;
    right: -12px;
    width: 60%;
    height: 60%;
    border-bottom: 2px solid var(--accent);
    border-right: 2px solid var(--accent);
    border-radius: 0 0 12px 0;
    z-index: 0;
  }

  /* Staggered reveal delays */
  .hero-text .reveal:nth-child(1) {
    transition-delay: 0.05s;
  }
  .hero-text .reveal:nth-child(2) {
    transition-delay: 0.1s;
  }
  .hero-text .reveal:nth-child(3) {
    transition-delay: 0.15s;
  }
  .hero-text .reveal:nth-child(4) {
    transition-delay: 0.2s;
  }
  .hero-text .reveal:nth-child(5) {
    transition-delay: 0.25s;
  }
  .hero-text .reveal:nth-child(6) {
    transition-delay: 0.3s;
  }
  .hero-photo.reveal {
    transition-delay: 0.2s;
  }

  /* Mobile photo clone — hidden on desktop */
  .hero-photo-mobile {
    display: none;
  }

  @media (max-width: 900px) {
    .hero-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 2rem;
    }

    /* Desktop photo: hidden on mobile */
    .hero-photo {
      display: none;
    }

    /* Top row: eyebrow+name left, photo right */
    .hero-top-row {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    /* Text block never shrinks */
    .hero-top {
      flex-shrink: 0;
    }

    /* Mobile photo: absorbs remaining space, can shrink */
    .hero-photo-mobile {
      display: block;
      position: relative;
      flex: 1;
      min-width: 0;
      max-width: 240px;
    }

    .hero-text {
      width: 100%;
      max-width: 100%;
      display: flex;
      flex-direction: column;
    }

    .hero-top-row {
      justify-content: space-between;
    }
  }

  @media (max-width: 480px) {
    .hero-name {
      font-size: clamp(3.5rem, 16vw, 5rem);
    }
    .hero-stats {
      gap: 1.5rem;
    }
  }
</style>
